NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=nutritracker
DB_PASSWORD=dev123456
DB_NAME=nutritracker_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=86400

# External APIs
OPENFOODFACTS_API_URL=https://world.openfoodfacts.org/api/v0
FATSECRET_API_KEY=your-fatsecret-key
FATSECRET_API_SECRET=your-fatsecret-secret

# Google Cloud Vision (OCR)
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project
GOOGLE_CLOUD_VISION_KEY=your-vision-api-key

# AWS (Optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# RevenueCat / Stripe
REVENUE_CAT_API_KEY=
STRIPE_SECRET_KEY=
